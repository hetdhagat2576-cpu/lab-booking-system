{
  "name": "lab-booking-backend",
  "version": "1.0.0",
  "description": "Backend API for Lab Booking System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed": "node seedUsers.js",
    "seed-tests": "node scripts/seedTests.js",
    "seed-packages": "node scripts/seedPackages.js",
    "seed-packages-stats": "node scripts/seedPackages.js stats",
    "seed-packages-clear": "node scripts/seedPackages.js clear",
