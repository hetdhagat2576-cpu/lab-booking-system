{
  "version": 2,
  "builds": [
    {
      "src": "api/test.js",
      "use": "@vercel/node",
      "config": {
        "functionName": "test-function"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "functionName": "lab-booking-backend-serverless"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/test",
      "dest": "/api/test.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
