{
  "version": 2,
  "builds": [
    {
      "src": "lab-booking-system/backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/lab-booking-system/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/lab-booking-system/backend/server.js"
    }
  ]
}
